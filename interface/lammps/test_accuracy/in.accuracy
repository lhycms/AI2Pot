units           metal
atom_style      atomic
boundary        p p p

read_data       data.gst

pair_style      ai2pot ./ai2pot_libtorch.pt
pair_coeff      * * Ge Sb Te

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

thermo          1
thermo_style    custom step atoms pe etotal press

dump            d1 all custom 1 force.dump id type x y z fx fy fz
dump_modify     d1 sort id first yes

run             1