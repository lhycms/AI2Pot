units           metal
atom_style      atomic
boundary        p p p

read_data       data.gst
replicate       10 10 10

pair_style      ai2pot ./nep_ai2pot_libtorch.pt
pair_coeff      * * Ge Sb Te

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

thermo          100

run             100