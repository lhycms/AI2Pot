   "source": [
    "# Installation\n",
    "## Step 1. Compile C++/CUDA\n",
    "```shell\n",
    "$ cd ${AI2POT_PATH}/source; mkdir build; cd build\n",
    "$ cmake -DBUILD_TEST=yes -DTORCH_OP=yes -DUSE_CUDA=yes -DMAX_MTP_LEVEL=20 -DUSE_OPENMP=yes ..\n",
    "$ make -j\n",
    "```\n",
    "\n",
    "## Step 2. Install python package\n",
    "```shell\n",
    "$ cd ${AI2POT_PATH}\n",
    "$ pip install .\n",
    "```"
   ]
  }
 ],
 "metadata": {
